# Provider options: openai | anthropic | azure-openai | ollama
TALKLY_PROVIDER=openai
TALKLY_MODEL=gpt-4o
TALKLY_ADMIN_KEY=your-secret-admin-key
PORT=3000

# Edit branding, scrape source, widget copy, tenant settings, and guardrails in:
# apps/server/src/instance/default/talkly.config.ts

# ── Provider credentials ──
# Only the variables for your chosen TALKLY_PROVIDER are required.

# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic (uses OpenAI for embeddings, so OPENAI_API_KEY is also required)
# ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_RESOURCE_NAME=your-resource-name
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Ollama (or any OpenAI-compatible local server: LM Studio, llama.cpp, vLLM).
# No API key required. Set TALKLY_PROVIDER=ollama and TALKLY_MODEL=llama3.2
# (or whatever model you've pulled).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_EMBEDDING_DIMENSIONS=768

# ── Infrastructure ──

# Set to 1 when Talkly runs behind a trusted reverse proxy (nginx, Cloudflare,
# Azure Front Door). When enabled, the first entry of X-Forwarded-For is used
# as the client IP for rate limiting. When unset, proxy headers are ignored
# and the socket remote address is used (correct for direct-exposed servers).
# TALKLY_TRUST_PROXY=0
