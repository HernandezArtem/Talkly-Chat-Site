{
  "name": "@talkly/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsup && node scripts/copy-widget.mjs",
    "dev": "node scripts/copy-widget.mjs && tsx watch --env-file=.env --env-file-if-exists=.env.local src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "onboard": "tsx src/scripts/setup.ts",
    "ingest": "tsx src/scripts/ingest.ts",
    "ingest:local": "tsx --env-file=.env.local src/scripts/ingest.ts",
    "scrape-ingest": "tsx src/scripts/scrape-ingest.ts",
    "scrape-ingest:local": "tsx --env-file=.env.local src/scripts/scrape-ingest.ts",
    "seed-demo": "tsx src/scripts/seed-demo.ts",
    "check-retrieval": "tsx src/scripts/check-retrieval.ts",
    "check-retrieval:local": "tsx --env-file=.env.local src/scripts/check-retrieval.ts",
    "report-chat-ops": "tsx src/scripts/report-chat-ops.ts",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@talkly/shared": "workspace:*",
    "@ai-sdk/anthropic": "^1",
    "@ai-sdk/azure": "^3.0.49",
    "@ai-sdk/openai": "^1",
    "@hono/node-server": "^1",
    "ai": "^4",
    "better-sqlite3": "^11",
    "cheerio": "^1.2.0",
    "hono": "^4",
    "sqlite-vec": "^0.1.7",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  }
}
